# Voice AI Pipeline - Environment Variables
# ==========================================
# Copy this to .env and fill in your keys

# OpenAI (for Whisper transcription)
OPENAI_API_KEY=sk-...

# Anthropic (for Claude intelligence)
ANTHROPIC_API_KEY=sk-ant-...

# Cartesia (for voice output)
CARTESIA_API_KEY=sk_car_...

# Optional: Custom Cartesia voice ID (if you've cloned your voice)
CARTESIA_VOICE_ID=

# TickTick (for task management)
# Get from: https://developer.ticktick.com/manage
TICKTICK_API_KEY=tp_...

# Server port (Railway sets this automatically)
PORT=8000
